{
  "manifest_version": 3,
  "name": "TAKCTRL - Hydro step",
  "version": "1.0",
  "description": "Stay hydrated and active with smart reminders. Mini Health AI for Developers & Desk Workers.",
  "permissions": ["notifications", "alarms", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
